{
  "name": "@devx-commerce/strapi-plugin-auto-translator",
  "version": "1.1.0",
  "description": "Automated translation plugin for Strapi v5 — supports OpenAI and AWS Translate providers",
  "repository": {
    "type": "git",
    "url": "https://github.com/devx-commerce/strapi-plugin-auto-translator.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "dist",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.tsx",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "verify": "strapi-plugin verify"
  },
  "strapi": {
    "name": "auto-translator",
    "displayName": "Auto Translator",
    "description": "Automatically translate Strapi v5 content across locales using OpenAI or AWS Translate",
    "kind": "plugin"
  },
  "dependencies": {
    "@strapi/design-system": "^2.0.0-rc.16",
    "@strapi/icons": "^2.0.0-rc.16"
  },
  "peerDependencies": {
    "@strapi/sdk-plugin": "^5.3.1",
    "@strapi/strapi": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0",
    "openai": ">=4.0.0",
    "@aws-sdk/client-translate": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@aws-sdk/client-translate": {
      "optional": true
    }
  },
  "devDependencies": {
    "@strapi/sdk-plugin": "^5.3.1",
    "@strapi/strapi": "^5.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "openai": "^6.32.0",
    "@aws-sdk/client-translate": "^3.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0",
    "typescript": "^5.0.0"
  },
  "author": {
    "name": "DevX Commerce"
  },
  "maintainers": [
    {
      "name": "DevX Commerce"
    }
  ],
  "engines": {
    "node": ">=18.0.0 <=22.x.x",
    "npm": ">=6.0.0"
  },
  "license": "MIT"
}
